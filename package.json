{
  "name": "ungarble",
  "version": "1.0.0",
  "description": "Fix garbled text from encoding errors",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mojibake",
    "encoding",
    "utf-8",
    "garbled"
  ],
  "author": "iruizsalinas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iruizsalinas/ungarble.git"
  },
  "homepage": "https://github.com/iruizsalinas/ungarble",
  "bugs": {
    "url": "https://github.com/iruizsalinas/ungarble/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsdown": "0.22.2",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "sideEffects": false
}
